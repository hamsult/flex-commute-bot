# Slack Bot Token (xoxb-로 시작)
# Slack App 생성 후 발급: https://api.slack.com/apps
# 필요 권한: chat:write, chat:write.public, im:history, im:read, im:write, users:read
SLACK_BOT_TOKEN=xoxb-your-token-here

# Slack App-Level Token (xapp-로 시작) — DM 커스터마이징 기능용 (선택)
# api.slack.com → 앱 선택 → Basic Information → App-Level Tokens → connections:write scope로 생성
# 없으면 DM 커스터마이징 기능만 비활성화, 근태 모니터링은 정상 동작
SLACK_APP_TOKEN=xapp-your-app-level-token-here
